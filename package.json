{
  "name": "dumplbot-pi",
  "version": "0.0.0",
  "private": true,
  "description": "DumplBot Pi scaffolding",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:host": "npm run build && npm run start:host",
    "smoke:audio-routes": "npm run build && node scripts/smoke-audio-routes.mjs",
    "smoke:audio-strict-policy": "npm run build && node scripts/smoke-audio-strict-policy.mjs",
    "smoke:install-pi": "node scripts/smoke-install-pi.mjs",
    "smoke:ui-core-gallery": "npm run build && node scripts/smoke-ui-core-gallery.mjs",
    "smoke:ui-appliance-gallery": "npm run build && node scripts/smoke-ui-appliance-gallery.mjs",
    "smoke:ui-debug-gallery": "npm run build && node scripts/smoke-ui-debug-gallery.mjs",
    "smoke:ui-navigation-gallery": "npm run build && node scripts/smoke-ui-navigation-gallery.mjs",
    "smoke:ui-scheduler-gallery": "npm run build && node scripts/smoke-ui-scheduler-gallery.mjs",
    "smoke:ui-skill-gallery": "npm run build && node scripts/smoke-ui-skill-gallery.mjs",
    "smoke:ui-workspace-gallery": "npm run build && node scripts/smoke-ui-workspace-gallery.mjs",
    "smoke:ui-review-bundle": "npm run build && node scripts/smoke-ui-review-bundle.mjs",
    "smoke:ui-run-cancel": "npm run build && node scripts/smoke-ui-run-cancel.mjs",
    "smoke:bash-tool-execution": "npm run build && node scripts/smoke-bash-tool-execution.mjs",
    "smoke:bash-prefix-policy": "npm run build && node scripts/smoke-bash-prefix-policy.mjs",
    "smoke:jobs-api": "npm run build && node scripts/smoke-jobs-api.mjs",
    "smoke:scheduler-history-retention": "npm run build && node scripts/smoke-scheduler-history-retention.mjs",
    "smoke:scheduler-loop": "npm run build && node scripts/smoke-scheduler-loop.mjs",
    "smoke:scheduler-runtime": "npm run build && node scripts/smoke-scheduler-runtime.mjs",
    "smoke:runner-bash-prefix": "npm run build && node scripts/smoke-runner-bash-prefix.mjs",
    "smoke:runner-bash-exec": "npm run build && node scripts/smoke-runner-bash-exec.mjs",
    "smoke:runner-sandbox-fs": "npm run build && node scripts/smoke-runner-sandbox-fs.mjs",
    "smoke:runner-sandbox-net": "npm run build && node scripts/smoke-runner-sandbox-net.mjs",
    "smoke:runner-sandbox-local": "npm run build && node scripts/smoke-runner-sandbox-local.mjs",
    "smoke:runner-policy-mismatch": "npm run build && node scripts/smoke-runner-policy-mismatch.mjs",
    "smoke:run-cancel": "npm run build && node scripts/smoke-run-cancel.mjs",
    "smoke:runner-sandbox-launch": "npm run build && node scripts/smoke-runner-sandbox-launch.mjs",
    "smoke:runner-timeout": "npm run build && node scripts/smoke-runner-timeout.mjs",
    "smoke:runner-launch-builder": "npm run build && node scripts/smoke-runner-launch-builder.mjs",
    "smoke:server-bind-config": "npm run build && node scripts/smoke-server-bind-config.mjs",
    "smoke:setup-lan-guard": "npm run build && node scripts/smoke-setup-lan-guard.mjs",
    "smoke:setup-page": "npm run build && node scripts/smoke-setup-page.mjs",
    "smoke:setup-secrets-runtime": "npm run build && node scripts/smoke-setup-secrets-runtime.mjs",
    "smoke:workspace-config": "npm run build && node scripts/smoke-workspace-config.mjs",
    "start:agent-runner": "node dist/apps/agent-runner/src/main.js",
    "start:host": "node dist/apps/host/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
